# ════════════════════════════════════════════════════════════
# EDIXDATA PLUG — Environment Variables (EXAMPLE ONLY)
# This file is safe to commit to GitHub
# Never put your real secret keys in this file!
# ════════════════════════════════════════════════════════════

# Paystack LIVE Secret Key
# → Add the REAL key ONLY in Railway → Service → Variables tab
# Do NOT put the real key here
PAYSTACK_SECRET=your_paystack_live_secret_key_here

# Your admin WhatsApp number
ADMIN_WA=233531861148

# Admin token - Make this VERY long and random (at least 64+ characters)
# Generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=your_very_long_random_secret_string_here_make_it_super_secure_and_long

# Server port (Railway will override this automatically)
PORT=3000
